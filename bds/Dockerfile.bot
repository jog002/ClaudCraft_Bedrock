FROM node:22

RUN apt-get update && apt-get install -y cmake build-essential && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files and install dependencies (with native builds)
COPY package*.json ./
RUN npm install --ignore-scripts && npm rebuild raknet-native

# Copy the rest of the app
COPY . .

# Build TypeScript
RUN npx tsc

CMD ["node", "dist/index.js"]
